# ─── Base de datos ───────────────────────────────────────────────────────────
POSTGRES_DB=smileos_dev
POSTGRES_USER=smileos
POSTGRES_PASSWORD=smileos_dev_password
DATABASE_URL=postgresql+asyncpg://smileos:smileos_dev_password@localhost:5432/smileos_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Seguridad ────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR-EN-PRODUCCION-minimo-32-caracteres-aleatorios
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Entorno ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Valores: development | staging | production

# ─── Oracle Object Storage (Fotografías) ─────────────────────────────────────
# Completar cuando se configure Oracle Cloud
OCI_NAMESPACE=
OCI_BUCKET_NAME=smileos-media
OCI_REGION=us-ashburn-1
OCI_TENANCY_OCID=
OCI_USER_OCID=
OCI_FINGERPRINT=
OCI_PRIVATE_KEY_PATH=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# En producción: solo el dominio del frontend
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── OpenAI (v1.0 — no requerido en MVP) ─────────────────────────────────────
OPENAI_API_KEY=
